# =================================================================================================
# Credentials for Server LSPaud1 (BiggerGuy)
#
# Environment Variables
# ---------------------
# HOST : str
#     IP address of the server.
# USER : str
#     Username for the server.
# PASS : str
#     Password for the server.
# PATH_KEY : str
#     Path on the local machine to the SSH key shared with the server.
# PASS_KEY : str, default=''
#     Password for the SSH key.
# ROOT : str
#     Root directory for the project on the server.
#
# Notes
# -----
# Home directory on the server: `HOME=/mnt/working2/$USER`
# Here, the environment variable `$HOME` is used directly.
# =================================================================================================

HOST=129.199.80.162
USER=esther
PASS=version1415

PATH_KEY=~/.ssh/id_ed25519
PASS_KEY=

ROOT=~/mtcdb
