# =================================================================================================
# Credentials for Server MarrsFreestyle (in LSP)
#
# Environment Variables
# ---------------------
# HOST : str
#     IP address of the server.
# USER : str
#     Username for the server.
# PASS : str
#     Password for the server.
# PATH_KEY : str
#     Path on the local machine to the SSH key shared with the server.
# PASS_KEY : str, default=''
#     Password for the SSH key.
# PROJECT : str
#     Name of the project directory on the server.
# ROOT : str
#     Root directory for the project on the server.
# =================================================================================================

HOST=129.199.80.205
USER=pierre
PASS=Boubenec96?

PATH_KEY=~/.ssh/id_ed25519
PASS_KEY=

PROJECT=esther-transfer-MDdata
ROOT=$HOME/Documents/$PROJECT
